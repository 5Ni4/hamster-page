---
import Layout from "../layouts/Layout.astro";
import Calendar from "../components/Calendar.astro";
import { fetchTopPageData, fetchPhotoDayList, distinctShootDates } from "../lib/nilto";

const fallbackData = {
  _title: "わが家の新人ハムスター",
  hamu_name: "ぽこちゃん",
  description: "さいきん　いえに　やってきた　ハムスターだよ㊗️",
  main_image: null as { url?: string; alt?: string } | null,
  skills: [] as Array<{ skill_name?: string }>,
};

const rawTop = await fetchTopPageData();
let data = { ...fallbackData, ...(rawTop ?? {}) };

const hasNilto =
  Boolean(import.meta.env.NILTO_API_KEY) &&
  (Boolean(import.meta.env.NILTO_CONTENT_URL) || Boolean(import.meta.env.NILTO_API_BASE));

if (!hasNilto) {
  console.warn(
    "NILTO の設定がありません。.env に NILTO_API_KEY と、NILTO_CONTENT_URL または NILTO_API_BASE を設定してください。"
  );
}

const title = data._title ?? fallbackData._title;
const hamu_name = (data.hamu_name ?? fallbackData.hamu_name).trim() || fallbackData.hamu_name;
const description = data.description ?? fallbackData.description;
const mainImage = data.main_image;
const imageUrl = mainImage?.url ?? "";
const imageAlt = mainImage?.alt || fallbackData.hamu_name;
const skills = (data.skills ?? []).map((s: { skill_name?: string }) => s?.skill_name ?? "").filter(Boolean);

const photoItems = await fetchPhotoDayList();
const linkedDates = new Set(distinctShootDates(photoItems));

const YEAR_MIN = 1900;
const YEAR_MAX = 2100;

const now = new Date();
let calYear = now.getFullYear();
let calMonth = now.getMonth();

const yRaw = Astro.url.searchParams.get("y");
const mRaw = Astro.url.searchParams.get("m");
if (yRaw != null && yRaw !== "" && mRaw != null && mRaw !== "") {
  const yParsed = Number.parseInt(yRaw, 10);
  const mParsed = Number.parseInt(mRaw, 10);
  if (
    Number.isFinite(yParsed) &&
    yParsed >= YEAR_MIN &&
    yParsed <= YEAR_MAX &&
    Number.isFinite(mParsed) &&
    mParsed >= 1 &&
    mParsed <= 12
  ) {
    calYear = yParsed;
    calMonth = mParsed - 1;
  }
}

function calendarHref(fullYear: number, month1to12: number): string {
  const q = new URLSearchParams();
  q.set("y", String(fullYear));
  q.set("m", String(month1to12));
  return `${Astro.url.pathname}?${q.toString()}`;
}

const prevMonthDate = new Date(calYear, calMonth - 1, 1);
const nextMonthDate = new Date(calYear, calMonth + 1, 1);
const calendarPrevHref = calendarHref(prevMonthDate.getFullYear(), prevMonthDate.getMonth() + 1);
const calendarNextHref = calendarHref(nextMonthDate.getFullYear(), nextMonthDate.getMonth() + 1);
const calendarPrevNavLabel = `${prevMonthDate.getFullYear()}年${prevMonthDate.getMonth() + 1}月へ`;
const calendarNextNavLabel = `${nextMonthDate.getFullYear()}年${nextMonthDate.getMonth() + 1}月へ`;
---

<Layout title={title}>
    <h1>{hamu_name}</h1>
    <p>{description}</p>
    {imageUrl && <img src={imageUrl} alt={imageAlt} width="300" />}

    <h2 class="skills-heading">とくいなこと</h2>
    <p class="skill-list">
      {skills.map((skill) => <span class="skill-tag">{skill}</span>)}
    </p>

    <hr />
    <section class="top-calendar" aria-labelledby="top-calendar-title">
      <h2 id="top-calendar-title" class="top-calendar-title">ぽこちゃんのアルバム</h2>
      <p class="top-calendar-lead">
        写真がある日だけ日付がリンクになります。タップするとその日のギャラリーページへ移動します。
      </p>
      <Calendar
        linkedDates={linkedDates}
        year={calYear}
        month={calMonth}
        prevHref={calendarPrevHref}
        nextHref={calendarNextHref}
        prevNavLabel={calendarPrevNavLabel}
        nextNavLabel={calendarNextNavLabel}
      />
    </section>

    <hr />
    <a href="/about" class="plain-link">飼い主について　→</a>
</Layout>
