---
import Analytics from '@vercel/analytics/astro';
const { title } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <Analytics />
  </body>
</html>

<style is:global>
  body {
    font-family: sans-serif;
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem;
    background-color: #b2d8f8;
    color: #444;
  }
  /* 画面幅が 480px 以下のとき */
  @media (max-width: 480px) {
    body {
      padding: 1rem;
    }
  }

  h1,
  h2,
  h3 {
    color: #df7bba;
  }

  h1 {
    background-color: #fff6d0;
    display: inline-block;
    border: 2px dashed #df7bba;
    padding: 0.2rem 0.5rem;
  }
  p {
    line-height: 1.6;
  }

  .profile-card {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .skill-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .skill-tag {
    background-color: #5be3cf;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .icon {
    font-size: 4rem;
  }

  .info {
    margin: 0;
    color: #39426b;
  }

  img {
    box-shadow: 4px 4px 0px #ffffff;
    display: block;
    margin: 1rem 0;
  }

  a {
    color: #df7bba;
    font-weight: bold;
    text-decoration: underline wavy;
  }

  .plain-link {
    color: inherit;
  }

  hr {
    border: none;
    border-top: 3px dashed #df7bba;
    margin: 1.5rem 0;
  }

  .top-calendar {
    margin: 0.25rem 0 0;
  }

  .top-calendar-title {
    margin: 0 0 0.35rem;
    font-size: 1.25rem;
  }

  .top-calendar-lead {
    margin: 0 0 0.85rem;
    font-size: 0.9rem;
    color: #39426b;
    line-height: 1.55;
  }

  .skills-heading {
    margin: 1.25rem 0 0.5rem;
    font-size: 1.15rem;
  }

  .calendar-section {
    margin-bottom: 0.5rem;
  }

  .calendar-heading {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: bold;
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    max-width: 100%;
    font-size: 0.9rem;
    text-align: center;
  }

  .calendar-dow {
    font-weight: bold;
    color: #39426b;
    padding: 0.2rem 0;
  }

  .calendar-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    border-radius: 4px;
    box-sizing: border-box;
  }

  .calendar-cell--empty {
    min-height: 2rem;
    pointer-events: none;
  }

  .calendar-cell--muted {
    color: #888;
    background: rgba(255, 255, 255, 0.35);
  }

  .calendar-cell--link {
    background-color: #fff6d0;
    border: 2px dashed #df7bba;
    color: #df7bba;
    font-weight: bold;
    text-decoration: none;
  }

  .calendar-cell--link:hover {
    background-color: #ffe8f0;
  }

  .album-page-heading {
    margin-top: 0.5rem;
  }

  .album-grid {
    list-style: none;
    margin: 1rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: 0.75rem;
  }

  .album-grid__item {
    margin: 0;
  }

  .album-grid__item img {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    margin: 0;
  }
</style>
