---
import Analytics from '@vercel/analytics/astro';
const { title } = Astro.props;
const currentYear = new Date().getFullYear();
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <footer class="site-footer" aria-label="サイト情報">
      <nav class="site-footer__links" aria-label="フッターリンク">
        <a href="/">トップ</a>
        <a href="/about">このサイトについて</a>
      </nav>
      <p class="site-footer__meta">
        &copy; <span id="current-year">{currentYear}</span> ぽこちゃんのアルバム ·
        <a href="https://nilto.com/" target="_blank" rel="noopener noreferrer">Powered by NILTO</a>
      </p>
    </footer>
    <Analytics />
    <script is:inline>
      const currentYearElement = document.getElementById("current-year");
      if (currentYearElement) {
        currentYearElement.textContent = String(new Date().getFullYear());
      }
    </script>
  </body>
</html>

<style is:global>
  body {
    font-family: sans-serif;
    max-width: 600px;
    margin: 0 auto;
    padding: 2rem;
    background-color: #b2d8f8;
    color: #444;
  }
  /* 画面幅が 480px 以下のとき */
  @media (max-width: 480px) {
    body {
      padding: 1rem;
    }
  }

  h1,
  h2,
  h3 {
    color: #df7bba;
  }

  h1 {
    background-color: #fff6d0;
    display: inline-block;
    border: 2px dashed #df7bba;
    padding: 0.2rem 0.5rem;
  }
  p {
    line-height: 1.6;
  }

  .profile-card {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .skill-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .skill-tag {
    background-color: #5be3cf;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
  }

  .icon {
    font-size: 4rem;
  }

  .info {
    margin: 0;
    color: #39426b;
  }

  img {
    box-shadow: 4px 4px 0px #ffffff;
    display: block;
    margin: 1rem 0;
  }

  a {
    color: #df7bba;
    font-weight: bold;
    text-decoration: underline wavy;
  }

  .plain-link {
    color: inherit;
  }

  .site-footer {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(57, 66, 107, 0.25);
    font-size: 0.75rem;
    color: rgba(57, 66, 107, 0.8);
    line-height: 1.7;
  }

  .site-footer__links {
    margin: 0;
    display: flex;
    gap: 0.85rem;
    flex-wrap: wrap;
  }

  .site-footer__links a {
    color: rgba(57, 66, 107, 0.8);
    font-weight: 500;
    text-decoration: none;
  }

  .site-footer__links a:hover {
    text-decoration: underline;
  }

  .site-footer__meta {
    margin: 0.3rem 0 0;
    color: rgba(57, 66, 107, 0.65);
  }

  .site-footer__meta a {
    color: inherit;
    font-weight: 400;
    text-decoration: none;
    border-bottom: 1px solid rgba(57, 66, 107, 0.35);
    padding-bottom: 1px;
  }

  .site-footer__meta a:hover {
    border-bottom-color: rgba(57, 66, 107, 0.6);
  }

  hr {
    border: none;
    border-top: 3px dashed #df7bba;
    margin: 1.5rem 0;
  }

  .top-calendar {
    margin: 0.25rem 0 0;
  }

  .top-calendar-title {
    margin: 0 0 0.35rem;
    font-size: 1.25rem;
  }

  .top-calendar-lead {
    margin: 0 0 0.85rem;
    font-size: 0.9rem;
    color: #39426b;
    line-height: 1.55;
  }

  .skills-heading {
    margin: 1.25rem 0 0.5rem;
    font-size: 1.15rem;
  }

  .calendar-section {
    margin-bottom: 0.5rem;
  }

  .calendar-heading-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 0.35rem 0.5rem;
    margin: 0 0 0.5rem;
  }

  .calendar-heading-row .calendar-heading {
    margin: 0;
    text-align: center;
  }

  .calendar-nav {
    font-size: 0.85rem;
    white-space: nowrap;
  }

  .calendar-heading {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: bold;
  }

  .calendar-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
    max-width: 100%;
    font-size: 0.9rem;
    text-align: center;
  }

  .calendar-dow {
    font-weight: bold;
    color: #39426b;
    padding: 0.2rem 0;
  }

  .calendar-cell {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    border-radius: 4px;
    box-sizing: border-box;
  }

  .calendar-cell--empty {
    min-height: 2rem;
    pointer-events: none;
  }

  .calendar-cell--muted {
    color: #888;
    background: rgba(255, 255, 255, 0.35);
  }

  .calendar-cell--link {
    background-color: #fff6d0;
    border: 2px dashed #df7bba;
    color: #df7bba;
    font-weight: bold;
    text-decoration: none;
  }

  .calendar-cell--link:hover {
    background-color: #ffe8f0;
  }

  body:has(.album-page) {
    max-width: min(100%, 56rem);
  }

  .album-page__nav {
    margin-bottom: 0.75rem;
  }

  .album-page__hero {
    margin: 0 0 1.75rem;
  }

  .album-page-heading {
    margin: 0 0 0.35rem;
    font-size: clamp(1.35rem, 4vw, 1.85rem);
    line-height: 1.25;
  }

  .album-page__meta {
    margin: 0;
    font-size: 0.95rem;
    color: #39426b;
    font-weight: 500;
  }

  .album-page__empty {
    margin: 0;
    padding: 1.5rem 1.25rem;
    background: rgba(255, 255, 255, 0.5);
    border: 2px dashed #c8d8ec;
    border-radius: 8px;
    color: #39426b;
    line-height: 1.65;
  }

  .album-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }

  @media (min-width: 540px) {
    .album-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: clamp(140px, 26vw, 220px);
    }
  }

  @media (min-width: 860px) {
    .album-grid {
      grid-auto-rows: clamp(160px, 18vw, 240px);
    }
  }

  .album-grid__item {
    margin: 0;
    background: rgba(255, 255, 255, 0.4);
    border-radius: 10px;
    padding: 0.25rem;
    border: none;
    box-shadow: none;
    height: 100%;
    box-sizing: border-box;
  }

  .album-grid__trigger {
    all: unset;
    display: block;
    width: 100%;
    height: 100%;
    cursor: zoom-in;
    border-radius: 10px;
    overflow: hidden;
    box-sizing: border-box;
    transition: transform 0.2s ease;
  }

  .album-grid__trigger:hover {
    transform: scale(1.03);
  }

  .album-grid__trigger:focus-visible {
    outline: 3px solid #df7bba;
    outline-offset: 3px;
  }

  .album-grid__frame {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 10px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.45);
  }

  /* 現在は同じ表示仕様だが、将来の差分追加に備えてクラスを分けている */
  .album-grid__frame--boxed img,
  .album-grid__frame--natural img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    margin: 0;
    border-radius: 0;
    box-shadow: none;
    pointer-events: none;
    display: block;
  }

  .album-lightbox {
    padding: 0;
    border: none;
    margin: 0;
    max-width: none;
    max-height: none;
    width: 100%;
    height: 100%;
    background: transparent;
  }

  .album-lightbox::backdrop {
    background: rgba(25, 35, 55, 0.82);
    backdrop-filter: blur(3px);
  }

  .album-lightbox__shell {
    width: 100%;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: min(5vw, 1.75rem);
    box-sizing: border-box;
    cursor: zoom-out;
  }

  .album-lightbox__figure {
    margin: 0;
    position: relative;
    max-width: min(94vw, 1200px);
    max-height: 90vh;
    cursor: default;
  }

  .album-lightbox__img {
    display: block;
    max-width: min(94vw, 1200px);
    max-height: 90vh;
    width: auto;
    height: auto;
    object-fit: contain;
    margin: 0;
    border-radius: 14px;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
  }

  .album-lightbox__close {
    position: absolute;
    top: -0.6rem;
    right: -0.6rem;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.95);
    color: #555;
    font-size: 1.25rem;
    font-weight: normal;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 1;
    transition: background 0.15s ease;
  }

  .album-lightbox__close:hover {
    background: #fff;
  }

  .album-lightbox__close:focus-visible {
    outline: 3px solid #5be3cf;
    outline-offset: 2px;
  }
</style>
